{
  "name": "dalchemist",
  "version": "0.0.1",
  "description": "",
  "main": "main.js",
  "type": "module",
  "scripts": {
    "outputAll": "npm run inventoryItemsInPricebook && npm run lowerCostsInventoryPricebookComparison && npm run checkPriceChangeWorksheetsAndInventory && npm run checkPriceChangeWorksheetsAndInventory-AllOutput  ",
    "inventoryItemsInPricebook": "babel-node src/Generators/inventoryItemsInPricebook.ts > src/Data/Outputs/inventoryItemsInPricebook.txt",
    "lowerCostsInventoryPricebookComparison": "node src/Generators/lowerCostsInventoryPricebookComparison.js > Data/Outputs/lowerCostsInventoryPricebookComparison.txt",
    "checkPriceChangeWorksheetsAndInventory": "node src/Generators/checkPriceChangeWorksheetsAndInventory.js > Data/Outputs/checkPriceChangeWorksheetsAndInventory.txt",
    "checkPriceChangeWorksheetsAndInventory-AllOutput": "node src/Generators/checkPriceChangeWorksheetsAndInventory.js --show-multiple-worksheet-items --show-same-priced-items > Data/Outputs/checkPriceChangeWorksheetsAndInventoryAllOutput.txt",
    "start": "nodemon --exec babel-node main.ts",
    "test": "jest",
    "lint": "npx eslint .",
    "docs": "typedoc",
    "docs-md": "typdoc --plugin typedoc-plugin-markdown --out docs/markdown"
  },
  "author": "Blake Glanville",
  "license": "BSD-3-Clause",
  "devDependencies": {
    "@babel/core": "^7.20.12",
    "@babel/node": "^7.20.7",
    "@babel/preset-env": "^7.20.2",
    "@babel/preset-typescript": "^7.18.6",
    "@jest/globals": "^29.4.1",
    "@types/express": "^4.17.16",
    "@typescript-eslint/eslint-plugin": "^5.49.0",
    "@typescript-eslint/parser": "^5.49.0",
    "eslint": "^8.32.0",
    "jest": "^29.4.1",
    "nodemon": "^2.0.20",
    "ts-jest": "^29.0.5",
    "typedoc": "^0.23.24",
    "typedoc-plugin-markdown": "^3.14.0",
    "typescript": "^4.9.4"
  },
  "dependencies": {
    "express": "^4.18.2",
    "prettier": "^2.8.3",
    "puppeteer": "^19.6.3",
    "tslib": "^2.5.0",
    "tslint-plugin-prettier": "^2.3.0"
  },
  "jest": {
    "collectCoverage": true,
    "coverageReporters": [
      "html"
    ]
  }
}
