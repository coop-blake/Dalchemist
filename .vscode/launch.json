{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Output UNFI price change item list",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run-script", "inventoryItemsInPricechange"]
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch checkPriceChangeWorksheetsAndInventory Program",
      "skipFiles": ["<node_internals>/**"],
      "runtimeExecutable": "${workspaceFolder}\\node_modules\\.bin\\ts-node",
      "program": "${workspaceFolder}\\src\\Generators\\checkPriceChangeWorksheetsAndInventory.ts"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch lowerCostsInventoryPricebookComparison Program",
      "skipFiles": ["<node_internals>/**"],
      "runtimeExecutable": "${workspaceFolder}\\node_modules\\.bin\\ts-node",
      "program": "${workspaceFolder}\\src\\Generators\\lowerCostsInventoryPricebookComparison.ts"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Create PDF From HTML",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}\\src\\ac\\createPDF.js"
    },
    {
      "name": "Launch outputAll via NPM",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run-script", "outputAll"]
    },
    {
      "name": "Launch checkPriceChangeWorksheetsAndInventory-AllOutput via NPM",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run-script",
        "checkPriceChangeWorksheetsAndInventory-AllOutput"
      ]
    },
    {
      "name": "Launch start via NPM",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run-script", "start"]
    },
    {
      "name": "Launch start Price Change via NPM",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run-script", "startPriceUpdate"]
    },
    {
      "name": "Launch lowerCostsInventoryPricebookComparison",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run-script", "lowerCostsInventoryPricebookComparison"]
    },
    {
      "name": "Launch checkSubdepartmentMargins",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run-script", "checkSubdepartmentMargins"]
    }
  ]
}
