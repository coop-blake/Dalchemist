{
  // Use IntelliSense to learn about possible attributes.
  // Hover to view descriptions of existing attributes.
  // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Duplicate Entries Program",
      "skipFiles": ["<node_internals>/**"],
      "runtimeExecutable": "${workspaceFolder}/node_modules/.bin/babel-node",
      "program": "${workspaceFolder}\\src\\Generators\\DuplicateEntriesCheck.ts"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch checkPriceChangeWorksheetsAndInventory Program",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}\\src\\Generators\\checkPriceChangeWorksheetsAndInventory.js"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch lowerCostsInventoryPricebookComparison Program",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}\\src\\Generators\\lowerCostsInventoryPricebookComparison.js"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Create PDF From HTML",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}\\src\\ac\\createPDF.js"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "Launch Main Program",
      "skipFiles": ["<node_internals>/**"],
      "program": "${workspaceFolder}\\src\\main.js"
    },
    {
      "name": "Launch via NPM",
      "type": "node",
      "request": "launch",
      "cwd": "${workspaceRoot}",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run-script", "outputAll"]
    }
  ]
}
